# ---- Supabase (server-side only — never exposed to the browser) ----
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SECRET_KEY=sb_secret_your_secret_key_here

# ---- Anthropic (AI assistant) ----
# Get a key at https://console.anthropic.com  (Settings -> API Keys)
ANTHROPIC_API_KEY=sk-ant-your_key_here
# Cheapest/fastest model; change to claude-sonnet-4-6 for stronger answers.
ASSISTANT_MODEL=claude-haiku-4-5

# ---- Site ----
# Your public URL (used for SEO sitemap/canonical). Set after first deploy.
NEXT_PUBLIC_SITE_URL=https://sponsortrack.vercel.app
